rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isHardcodedAdmin() {
      return isSignedIn() && request.auth.token.email.lower() == 'nandhanandha2425@gmail.com';
    }

    function isAdmin() {
      return isHardcodedAdmin() || (isSignedIn() && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isSeller() {
      return isHardcodedAdmin() || (isSignedIn() && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.role in ['acquirer', 'seller', 'admin'] &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidBusiness(data) {
      return data.keys().hasAll(['title', 'category', 'price', 'location', 'ownerId', 'status', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.category in ['Micro Business', 'Partnership Sale', 'Full Business Sale', 'Investment Opportunity'] &&
             data.price is number && data.price >= 0 &&
             data.ownerId == request.auth.uid &&
             data.status in ['under_review', 'approved', 'rejected'] &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if (isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'businessName', 'location', 'subscription', 'role', 'createdAt', 'photoURL']) &&
        (incoming().role != 'admin' || (existing() != null && existing().role == 'admin'))
      )) || isAdmin();
    }

    // BUSINESSES
    match /businesses/{businessId} {
      allow get: if true;
      allow list: if existing().status == 'approved' || isOwner(existing().ownerId) || isAdmin();

      allow create: if isSeller() && isValidBusiness(incoming());
      
      allow update: if (
        // Action: Owner update
        (isOwner(existing().ownerId) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'location', 'images', 'documents', 'revenue', 'profit', 'yearsOfOperation'])) ||
        // Action: Admin update
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    // PLAN REQUESTS
    match /plan_requests/{requestId} {
      allow list: if isAdmin() || isOwner(existing().assetOwnerId); 
      allow get: if isAdmin() || isOwner(existing().assetOwnerId);
      allow create: if isSeller() && incoming().assetOwnerId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ENQUIRIES
    match /enquiries/{enquiryId} {
      allow create: if isSignedIn() && incoming().acquirerId == request.auth.uid;
      allow list: if isSignedIn() && (existing().acquirerId == request.auth.uid || existing().ownerId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (existing().acquirerId == request.auth.uid || existing().ownerId == request.auth.uid || isAdmin());
    }

    // CHATS
    match /chats/{msgId} {
      allow list: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow get: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants && request.resource.data.senderId == request.auth.uid;
    }

    // NOTIFICATIONS
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
    }

    // SUBSCRIPTIONS
    match /subscriptions/{subId} {
      allow read: if isAdmin() || isOwner(resource.data.assetOwnerId);
      allow write: if isAdmin();
    }
  }
}
